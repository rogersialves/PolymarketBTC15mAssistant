# =============================================================================
# 1. CORE
# =============================================================================
CANDLE_WINDOW_MINUTES=15

# =============================================================================
# 2. BINANCE
# =============================================================================
BINANCE_BASE_URLS=https://api.binance.com,https://api.binance.us
# BINANCE_WS_BASE_URL=wss://stream.binance.us:9443
# BINANCE_KLINES_CACHE_MS=2000

# =============================================================================
# 3. POLYMARKET — Gamma + CLOB (mercado e UP/DOWN)
# =============================================================================
POLYMARKET_SNAPSHOT_CLOB_BUDGET_MS=1500
# Refetch Gamma /events — menor = mercado novo após viragem mais cedo (default código: 15000).
POLYMARKET_RESOLVE_CACHE_MS=15000
POLYMARKET_SNAPSHOT_TIMEOUT_MS=5000
POLYMARKET_CLOB_FETCH_INTERVAL_MS=3000
POLYMARKET_CLOB_CACHE_TTL_MS=5000
POLYMARKET_CLOB_FETCH_TIMEOUT_MS=1500

# =============================================================================
# 4. POLYMARKET / SCALP — PTB na viragem e tick
# =============================================================================
SCALP_PTB_WARMUP_MS=10000
POLYMARKET_CURRENT_PRICE_MAX_AGE_MS=1500
POLYMARKET_LIVE_WS_URL=wss://ws-live-data.polymarket.com
CHAINLINK_STEP_TIMEOUT_MS=3500
# SCALP_DISABLE_POLY_WS=1
# SCALP_DISABLE_CHAINLINK_WS=1

# =============================================================================
# 5. MOTOR / HTTP
# =============================================================================
HTTP_TIMEOUT_MS=4000
ENGINE_TICK_TIMEOUT_MS=8000
ENGINE_SLOW_TICK_MS=3000
ENGINE_WATCHDOG_MS=6000
BINANCE_FAILOVER_BUDGET_MS=5000
BINANCE_REFRESH_RETRY_MS=15000
TRADE_HISTORY_SAVE_DEBOUNCE_MS=5000

# =============================================================================
# 6. PERSISTÊNCIA (opcional — copiar para .env local)
# =============================================================================
# TRADE_HISTORY_SOURCE=postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/polymarket_bot

# =============================================================================
# 7. CHAINLINK (Polygon)
# =============================================================================
POLYGON_RPC_URLS=https://polygon-bor-rpc.publicnode.com
POLYGON_WSS_URLS=wss://polygon-bor-rpc.publicnode.com
CHAINLINK_NETWORK_BUDGET_MS=1500
CHAINLINK_HTTP_HEARTBEAT_MS=10000

# =============================================================================
# 8. LOGS
# =============================================================================
LOG_MAX_AGE_DAYS=7

# =============================================================================
# 9. POLYMARKET — CARTEIRA / CLOB
# =============================================================================
POLY_PRIVATE_KEY=
POLY_DRY_RUN=true
POLY_MAX_STAKE=40
POLY_CHAIN_ID=137
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_SIGNATURE_TYPE=0
POLY_FUNDER_ADDRESS=<your-proxy-wallet-address>
RELAYER_API_KEY=<your-api-key>
RELAYER_API_KEY_ADDRESS=<relayer-key-address>
