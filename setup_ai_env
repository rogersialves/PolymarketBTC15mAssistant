def copy_context_mode(source: Path, target: Path, force: bool) -> str:
    if not source.exists():
        return f"skipped context-mode copy; source missing: {source}"
    dest = target / "plugins" / "context-mode"
    if dest.exists() and not force:
        return f"kept {dest}"
    if dest.exists():
        shutil.rmtree(dest)
    ignore = shutil.ignore_patterns("node_modules", ".git", "coverage", "dist", "build")
    shutil.copytree(source, dest, ignore=ignore)
    return f"copied {source} -> {dest}"


def install_user_hooks(project_root: Path, hooks_data: dict, force: bool) -> str:
    hooks_path = Path.home() / ".codex" / "hooks.json"
    hooks_path.parent.mkdir(parents=True, exist_ok=True)
    if hooks_path.exists():
        backup = hooks_path.with_suffix(f".json.backup-{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}")
        shutil.copy2(hooks_path, backup)
        backup_msg = f"backup {backup}; "
    else:
        backup_msg = ""
    if hooks_path.exists() and not force:
        # Installing hooks is explicit; overwrite after backup because the flag was requested.
        pass
    hooks_path.write_text(json.dumps(hooks_data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    return f"{backup_msg}installed {hooks_path} for {project_root}"


def scaffold(args: argparse.Namespace) -> list[str]:
    project_root = Path(args.target).expanduser().resolve()
    project_name = args.project_name or project_root.name
    force = bool(args.force)
    project_root.mkdir(parents=True, exist_ok=True)

    actions: list[str] = []
    if args.copy_context_mode_from:
        actions.append(copy_context_mode(Path(args.copy_context_mode_from).expanduser().resolve(), project_root, force))

    mode = args.context_mode
    mcp_server = context_mode_mcp(project_root, mode)
    hooks_data = codex_hooks(project_root, mode)

    actions.append(write_text(project_root / "AGENTS.md", agent_instructions(project_name), force))
    actions.append(write_text(project_root / "MEMORY.md", memory_md(project_name), force))
    actions.append(write_text(project_root / ".env.example", env_example(), force))
    actions.append(write_json(project_root / ".vscode" / "settings.json", {
        "claudeCode.allowDangerouslySkipPermissions": False,
        "claudeCode.initialPermissionMode": "default",
    }, force))
    actions.append(write_json(project_root / ".mcp.json", {"mcpServers": {"context-mode": mcp_server}}, force))
    actions.append(write_json(project_root / ".vscode" / "mcp.json", {"servers": {"context-mode": mcp_server}}, force))
    actions.append(write_json(project_root / ".codex" / "hooks.json", hooks_data, force))
    actions.append(write_json(project_root / ".agents" / "plugins" / "marketplace.json", {
        "name": f"{project_name.lower()}-local",
        "interface": {"displayName": f"{project_name} Local Plugins"},
        "plugins": [
            {
                "name": "context-mode",
                "source": {"source": "local", "path": "./plugins/context-mode"},
                "policy": {"installation": "AVAILABLE", "authentication": "ON_INSTALL"},
                "category": "Coding",
            }
        ],
    }, force))
    actions.append(write_text(project_root / "prompts" / "system.md", f"""# {project_name} System Prompt

Use `AGENTS.md` for project-specific operating rules.
Use `memory/obsidian-vault` as durable project memory.
Never place secrets in prompts, vault notes, or committed config.
""", force))
    actions.append(write_text(project_root / "scripts" / "obsidian-memory-hook.mjs", obsidian_hook(project_name), force, executable=True))
    actions.extend(vault_files(project_root, project_name, force))

    if args.install_codex_user_hooks:
        actions.append(install_user_hooks(project_root, hooks_data, force))

    return actions


def main() -> int:
    parser = argparse.ArgumentParser(description="Scaffold AI/agent/MCP/Obsidian memory environment.")
    parser.add_argument("target", nargs="?", default=".", help="Target project directory. Defaults to current directory.")
    parser.add_argument("--project-name", help="Logical project name. Defaults to target directory name.")
    parser.add_argument("--context-mode", choices=["auto", "local", "npx"], default="auto", help="How to render context-mode commands.")
    parser.add_argument("--copy-context-mode-from", help="Optional source directory to vendor-copy plugins/context-mode, excluding node_modules.")
    parser.add_argument("--install-codex-user-hooks", action="store_true", help="Write ~/.codex/hooks.json with a timestamped backup.")
    parser.add_argument("--force", action="store_true", help="Overwrite files that already exist.")
    parser.add_argument("--version", action="version", version=f"setup_ai_env {ROOT_FILES_VERSION}")
    args = parser.parse_args()

    actions = scaffold(args)
    print("setup_ai_env complete")
    for action in actions:
        print(f"- {action}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
