def obsidian_hook(project_name: str) -> str:
    return f"""#!/usr/bin/env node
import {{ appendFileSync, existsSync, mkdirSync, readdirSync, readFileSync, renameSync, writeFileSync }} from "node:fs";
import {{ dirname, join, resolve }} from "node:path";
import {{ fileURLToPath }} from "node:url";

const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), "..");
const vaultRoot = join(repoRoot, "memory", "obsidian-vault");
const sessionsDir = join(vaultRoot, "10-Sessions");
const inboxDir = join(vaultRoot, "00-Inbox");
const indexPath = join(vaultRoot, "Memory Index.md");
const projectName = "{project_name}";

const event = process.argv[2] || process.env.HOOK_EVENT || "SessionStart";

async function readInput() {{
  try {{
    const chunks = [];
    for await (const chunk of process.stdin) chunks.push(chunk);
    const raw = Buffer.concat(chunks).toString("utf8").trim();
    return raw ? JSON.parse(raw) : {{}};
  }} catch {{
    return {{}};
  }}
}}

function sessionId(input) {{
  return input.session_id || input.sessionId || process.env.CODEX_SESSION_ID || process.env.CODEX_THREAD_ID || "manual";
}}

function projectDir(input) {{
  return input.cwd || input.project_dir || input.projectDir || process.env.CONTEXT_MODE_PROJECT_DIR || repoRoot;
}}

function nowIso() {{
  return new Date().toISOString();
}}

function jsonScalar(value) {{
  return JSON.stringify(String(value ?? ""));
}}

function monthName(date) {{
  const months = ["Janeiro", "Fevereiro", "Marco", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
  return `${{String(date.getUTCMonth() + 1).padStart(2, "0")}}-${{months[date.getUTCMonth()]}}`;
}}

function cleanTitle(value) {{
  return String(value || "Sessao iniciada")
    .normalize("NFKD")
    .replace(/[\\u0300-\\u036f]/g, "")
    .replace(/[^a-zA-Z0-9._ -]/g, " ")
    .replace(/\\s+/g, " ")
    .trim()
    .slice(0, 90) || "Sessao iniciada";
}}

function firstPrompt(input) {{
  return input.prompt || input.userPrompt || input.message || input.text || "";
}}

function ensureVault() {{
  for (const dir of [vaultRoot, sessionsDir, inboxDir]) mkdirSync(dir, {{ recursive: true }});
  if (!existsSync(indexPath)) {{
    writeFileSync(indexPath, [
      "# Memory Index",
      "",
      `Vault Obsidian do projeto ${{projectName}}.`,
      "",
      "## Como usar",
      "",
      "- `10-Sessions/` recebe registros automaticos de sessoes do Codex.",
      "- `20-Decisions/` guarda decisoes tecnicas estaveis.",
      "- `30-Runbooks/` guarda procedimentos operacionais.",
      "- `40-Incidents/` guarda bugs, incidentes e analises pos-correcao.",
      "",
      "## Sessoes recentes",
      "",
    ].join("\\n"), "utf8");
  }}
}}

function walk(dir) {{
  if (!existsSync(dir)) return [];
  const out = [];
  for (const name of readdirSync(dir, {{ withFileTypes: true }})) {{
    const full = join(dir, name.name);
    if (name.isDirectory()) out.push(...walk(full));
    else if (name.isFile() && name.name.endsWith(".md")) out.push(full);
  }}
  return out;
}}

function findSession(id) {{
  const marker = `session_id: ${{jsonScalar(id)}}`;
  return walk(sessionsDir).find((file) => readFileSync(file, "utf8").includes(marker));
}}

function vaultRelative(file) {{
  return file.replace(vaultRoot + "/", "").replace(/\\.md$/, "");
}}

function createSession(input) {{
  const date = new Date();
  const year = String(date.getUTCFullYear());
  const folder = join(sessionsDir, year, monthName(date));
  mkdirSync(folder, {{ recursive: true }});
  const stamp = `${{String(date.getUTCHours()).padStart(2, "0")}}-${{String(date.getUTCMinutes()).padStart(2, "0")}}-${{String(date.getUTCSeconds()).padStart(2, "0")}}`;
  const title = cleanTitle(firstPrompt(input) || "Sessao iniciada");
  const file = join(folder, `${{stamp}} - ${{title}}.md`);
  const created = nowIso();
  writeFileSync(file, [
    "---",
    `title: ${{jsonScalar(title)}}`,
    "type: chat-session",
    "status: active",
    `session_id: ${{jsonScalar(sessionId(input))}}`,
    `project: ${{jsonScalar(projectName)}}`,
    `project_dir: ${{jsonScalar(projectDir(input))}}`,
    `created: ${{jsonScalar(created)}}`,
    `updated: ${{jsonScalar(created)}}`,
    `source: ${{jsonScalar(input.source || event)}}`,
    "tags:",
    "  - memory/session",
    "  - codex",
    "---",
    "",
    `# ${{title}}`,
    "",
    "Links: [[Memory Index]]",
    "",
    "## Timeline",
    "",
    `- ${{created}} SessionStart`,
    "",
  ].join("\\n"), "utf8");
  appendFileSync(indexPath, `- [[${{vaultRelative(file)}}|${{title}}]] - ${{created}}\\n`);
  return file;
}}

function sessionFile(input) {{
  return findSession(sessionId(input)) || createSession(input);
}}

function maybeRenameFromPrompt(file, input) {{
  const prompt = firstPrompt(input);
  if (!prompt || !file.includes("Sessao iniciada")) return file;
  const next = join(dirname(file), file.split("/").pop().replace("Sessao iniciada", cleanTitle(prompt)));
  if (next !== file && !existsSync(next)) {{
    renameSync(file, next);
    return next;
  }}
  return file;
}}

function appendEvent(file, input, name) {{
  const ts = nowIso();
  const prompt = firstPrompt(input);
  appendFileSync(file, `\\n- ${{ts}} ${{name}}\\n`, "utf8");
  if (name === "UserPromptSubmit" && prompt) appendFileSync(file, `\\n### User Prompt\\n\\n${{prompt}}\\n`, "utf8");
  const body = readFileSync(file, "utf8")
    .replace(/status: active|status: ended/, name === "Stop" ? "status: ended" : "status: active")
    .replace(/updated: .*/, `updated: ${{jsonScalar(ts)}}`);
  writeFileSync(file, body, "utf8");
}}

const input = await readInput();
ensureVault();
let file = sessionFile(input);
if (event === "UserPromptSubmit") file = maybeRenameFromPrompt(file, input);
appendEvent(file, input, event);

if (event === "Stop") process.stdout.write("{{}}");
else process.stdout.write(JSON.stringify({{ hookSpecificOutput: {{ hookEventName: event }} }}));
"""


