#!/usr/bin/env python3
"""Scaffold AI agent, MCP, context-mode, and Obsidian memory files.

Usage:
  ./setup_ai_env /path/to/project --project-name MyProject
  ./setup_ai_env . --install-codex-user-hooks
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
from datetime import datetime, timezone
from pathlib import Path


ROOT_FILES_VERSION = "2026-05-01"


def write_text(path: Path, text: str, force: bool = False, executable: bool = False) -> str:
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.exists() and not force:
        return f"kept {path}"
    path.write_text(text.rstrip() + "\n", encoding="utf-8")
    if executable:
        path.chmod(path.stat().st_mode | 0o755)
    return f"wrote {path}"


def write_json(path: Path, data: object, force: bool = False) -> str:
    return write_text(path, json.dumps(data, indent=2, ensure_ascii=False), force)


def touch(path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.touch(exist_ok=True)


def context_mode_local_available(project_root: Path) -> bool:
    return (project_root / "plugins" / "context-mode" / "start.mjs").exists()


def context_mode_mcp(project_root: Path, mode: str) -> dict:
    use_local = mode == "local" or (mode == "auto" and context_mode_local_available(project_root))
    if use_local:
        return {
            "command": "node",
            "args": [str(project_root / "plugins" / "context-mode" / "start.mjs")],
            "env": {"CONTEXT_MODE_PROJECT_DIR": str(project_root)},
        }
    return {
        "command": "npx",
        "args": ["-y", "context-mode"],
        "env": {"CONTEXT_MODE_PROJECT_DIR": str(project_root)},
    }


def context_mode_hook_command(project_root: Path, event: str, mode: str) -> str:
    use_local = mode == "local" or (mode == "auto" and context_mode_local_available(project_root))
    if use_local:
        return f"node {project_root / 'plugins' / 'context-mode' / 'hooks' / 'codex' / (event + '.mjs')}"
    return f"context-mode hook codex {event}"


def codex_hooks(project_root: Path, mode: str) -> dict:
    obsidian_hook = project_root / "scripts" / "obsidian-memory-hook.mjs"

    def cmd(command: str) -> dict:
        return {"type": "command", "command": command}

    return {
        "hooks": {
            "PreToolUse": [{"hooks": [cmd(context_mode_hook_command(project_root, "pretooluse", mode))]}],
            "PostToolUse": [{"hooks": [cmd(context_mode_hook_command(project_root, "posttooluse", mode))]}],
            "SessionStart": [
                {
                    "hooks": [
                        cmd(context_mode_hook_command(project_root, "sessionstart", mode)),
                        cmd(f"node {obsidian_hook} SessionStart"),
                    ]
                }
            ],
            "UserPromptSubmit": [
                {
                    "hooks": [
                        cmd(context_mode_hook_command(project_root, "userpromptsubmit", mode)),
                        cmd(f"node {obsidian_hook} UserPromptSubmit"),
                    ]
                }
            ],
            "Stop": [
                {
                    "hooks": [
                        cmd(context_mode_hook_command(project_root, "stop", mode)),
                        cmd(f"node {obsidian_hook} Stop"),
                    ]
                }
            ],
        }
    }


